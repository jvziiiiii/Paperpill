# Copy this file to `.env` and fill in your key. Never commit `.env`.
# Vite only exposes variables that start with VITE_
#
# `npm run dev`: requests go through a local proxy (no CORS issues).
# `npm run preview` / real hosting: you need your own backend or a host that allows browser calls.

VITE_PAPER_PILL_API_KEY=

# Set to true only if you must bypass the dev proxy (usually breaks in browser due to CORS)
# VITE_PAPER_PILL_NO_PROXY=true

# Optional overrides (defaults match DeepSeek)
# VITE_PAPER_PILL_API_URL=https://api.deepseek.com/v1/chat/completions
# VITE_PAPER_PILL_API_MODEL=deepseek-chat

# Moonshot example:
# VITE_PAPER_PILL_API_URL=https://api.moonshot.cn/v1/chat/completions
# VITE_PAPER_PILL_API_MODEL=moonshot-v1-8k
